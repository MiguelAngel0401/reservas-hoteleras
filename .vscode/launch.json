{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "AuthApplication",
            "request": "launch",
            "mainClass": "com.hotel.auth.AuthApplication",
            "projectName": "auth",
            "env": {
                "DB_URL": "jdbc:oracle:thin:@//localhost:1521/FREEPDB1",
                "DB_PASS": "admin",
                "DB_USER": "admin"
            }
        },
        {
            "type": "java",
            "name": "CommonsApplication",
            "request": "launch",
            "mainClass": "com.hotel.commons.CommonsApplication",
            "projectName": "commons"
        },
        {
            "type": "java",
            "name": "EurekaServerApplication",
            "request": "launch",
            "mainClass": "com.hotel.eureka_server.EurekaServerApplication",
            "projectName": "eureka-server",
            "vmArgs": " -Dcom.sun.management.jmxremote -Dcom.sun.management.jmxremote.port=40929 -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false -Dspring.jmx.enabled=true -Djava.rmi.server.hostname=localhost -Dspring.application.admin.enabled=true -Dspring.boot.project.name=eureka-server"
        },
        {
            "type": "java",
            "name": "GatewayApplication",
            "request": "launch",
            "mainClass": "com.hotel.gateway.GatewayApplication",
            "projectName": "gateway",
            "vmArgs": " -Dcom.sun.management.jmxremote -Dcom.sun.management.jmxremote.port=46869 -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false -Dspring.jmx.enabled=true -Djava.rmi.server.hostname=localhost -Dspring.application.admin.enabled=true -Dspring.boot.project.name=gateway"
        },
        {
            "type": "java",
            "name": "HuespedesApplication",
            "request": "launch",
            "mainClass": "com.hotel.huespedes.HuespedesApplication",
            "projectName": "huespedes",
            "env": {
                "DB_URL": "jdbc:oracle:thin:@//localhost:1521/FREEPDB1",
                "DB_PASS": "admin",
                "DB_USER": "admin",
                "PORT": "8082"
            }
        },
        {
            "type": "java",
            "name": "Spring Boot-AuthorizationServerApplication<authorization-server>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.hotel.auth.AuthorizationServerApplication",
            "projectName": "authorization-server",
             "env": {
                "DB_URL": "jdbc:oracle:thin:@//localhost:1521/FREEPDB1",
                "DB_PASS": "admin",
                "DB_USER": "admin"
            },
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}